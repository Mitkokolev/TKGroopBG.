@{
    ViewData["Title"] = "Количка";
}

<div class="cart-container">
    <h2>Вашата количка</h2>

    <div id="cartItems"></div>

    <div class="cart-footer">
        <h4>Общо: <span id="totalPrice">0.00</span> лв</h4>
        <a href="/Cart/Order" class="btn btn-success">Поръчай</a>
    </div>
</div>

<script>
    let cart = JSON.parse(localStorage.getItem("tk_cart")) || [];
    let container = document.getElementById("cartItems");
    let total = 0;

    if (cart.length === 0) {
        container.innerHTML = "<p>Количката е празна.</p>";
    }

    cart.forEach((p, i) => {

        total += Number(p.price) * (p.qty || 1);

        container.innerHTML += `
            <div class="cart-item">
                <img src="${p.image}" style="height:80px;border-radius:10px;margin-right:15px" />

                <div class="cart-info">
                    <h5>${p.name}</h5>
                    <p>${Number(p.price).toFixed(2)} лв × ${p.qty || 1}</p>
                </div>

                <button onclick="removeItem(${i})"
                        class="btn btn-sm btn-danger">
                    Премахни
                </button>
            </div>
        `;
    });

    document.getElementById("totalPrice").innerText = total.toFixed(2);


    function removeItem(i){
        let cart = JSON.parse(localStorage.getItem("tk_cart")) || [];
        cart.splice(i,1);
        localStorage.setItem("tk_cart", JSON.stringify(cart));
        location.reload();
    }
</script>