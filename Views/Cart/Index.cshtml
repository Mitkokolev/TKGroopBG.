@model IEnumerable<TKGroopBG.Models.Cart>

@{
    ViewData["Title"] = "Количка";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm p-4 border-0">
                <h4 class="mb-4"><i class="fas fa-shopping-cart text-danger"></i> Вашата количка</h4>

                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Продукт</th>
                                    <th>Цена</th>
                                    <th>Количество</th>
                                    <th>Общо</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr id="row-@item.Id">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (item.Product != null)
                                                {
                                                    <img src="/product-images/@item.Product.ImageFileName"
                                                         class="rounded me-3 shadow-sm"
                                                         style="width: 60px; height: 60px; object-fit: cover;"
                                                         onerror="this.src='/images/no-image.png'">
                                                    <div>
                                                        <div class="fw-bold text-dark">@item.Product.Name</div>
                                                        @if (!string.IsNullOrEmpty(item.Details))
                                                        {
                                                            <small class="text-muted d-block" style="font-size: 0.8rem;">
                                                                <i class="fas fa-info-circle me-1"></i> @item.Details
                                                            </small>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                        <td>@item.Product?.Price.ToString("F2") лв.</td>
                                        <td>
                                            <span class="badge bg-light text-dark border p-2">@item.Quantity бр.</span>
                                        </td>
                                        <td class="fw-bold text-danger">@((item.Product?.Price * item.Quantity)?.ToString("F2")) лв.</td>
                                        <td class="text-end">
                                            @Html.AntiForgeryToken()
                                            <button onclick="removeFromCart(@item.Id)" class="btn btn-sm btn-link text-danger p-0">
                                                <i class="fas fa-trash-alt fa-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <hr />
                    <div class="text-end py-2">
                        <span class="text-muted me-2">Обща сума за плащане:</span>
                        <h4 class="d-inline-block text-danger fw-bold">@Model.Sum(x => x.Quantity * (x.Product?.Price ?? 0)).ToString("F2") лв.</h4>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-shopping-basket fa-4x text-light mb-3"></i>
                        <h5 class="text-muted">Количката е празна</h5>
                        <a href="/Products" class="btn btn-outline-danger mt-3 rounded-pill px-4">Към продуктите</a>
                    </div>
                }
            </div>
        </div>

        @* ДЯСНА ЧАСТ: БУТОН ЗА ПОРЪЧКА *@
        <div class="col-md-4">
            <div class="card shadow-sm p-4 border-0 bg-light">
                <h5 class="mb-3 fw-bold">Обобщение</h5>
                <div class="d-flex justify-content-between mb-4">
                    <span>Продукти:</span>
                    <span>@Model?.Count()</span>
                </div>

                @* ВАЖНО: Този линк води към [HttpGet] Order() *@
                <a href="/Cart/Order" class="btn btn-danger btn-lg w-100 py-3 fw-bold shadow-sm @(Model == null || !Model.Any() ? "disabled" : "")">
                    КЪМ ЗАВЪРШВАНЕ <i class="fas fa-chevron-right ms-2"></i>
                </a>

                <p class="text-muted small mt-3 text-center">
                    <i class="fas fa-shield-alt me-1"></i> Сигурна поръчка през TKGroopBG
                </p>
            </div>
        </div>
    </div>
</div>