@model TKGroopBG.Models.OrderRequest

<div class="order-box">
    <h2 class="text-center mb-4">Данни за поръчка</h2>

    <form method="post" action="/Cart/SubmitOrder">
        @Html.AntiForgeryToken()

        <input asp-for="CustomerName" class="form-control mb-3" placeholder="Име" required />
        <input asp-for="Phone" class="form-control mb-3" placeholder="Телефон" required />
        <input asp-for="Email" class="form-control mb-3" placeholder="Email" />
        <input asp-for="Address" class="form-control mb-3" placeholder="Адрес" required />
        <textarea asp-for="Comment" class="form-control mb-3" placeholder="Коментар"></textarea>

        <input type="hidden" id="cartJson" name="CartJson" />

        <button class="btn btn-danger w-100">Изпрати поръчка</button>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.getElementById("cartJson").value =
            localStorage.getItem("tk_cart") || "";
    });
</script>