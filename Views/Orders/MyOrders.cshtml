@model IEnumerable<TKGroopBG.Models.Orders>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-box text-danger"></i> Моите поръчки</h2>
        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill">Към магазина</a>
    </div>

    <p class="text-muted">Здравейте, тук можете да следите историята и статуса на вашите поръчки.</p>

    <div class="card shadow-sm border-0 mt-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">№ Поръчка</th>
                        <th>Дата</th>
                        <th>Сума</th>
                        <th>Статус</th>
                        <th class="text-center">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@order.Id</td>
                                <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="fw-bold text-danger">@order.TotalPrice.ToString("F2") €</td>
                                <td>
                                    @if (order.Status == "Нова")
                                    {
                                        <span class="badge bg-primary rounded-pill px-3">Нова</span>
                                    }
                                    else if (order.Status == "Изпратена")
                                    {
                                        <span class="badge bg-info rounded-pill px-3">Изпратена</span>
                                    }
                                    else if (order.Status == "Завършена")
                                    {
                                        <span class="badge bg-success rounded-pill px-3">Завършена</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">@order.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-danger rounded-pill px-3 shadow-sm">
                                        <i class="fas fa-eye me-1"></i> Детайли
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-shopping-bag fa-3x text-light mb-3 d-block"></i>
                                <p class="text-muted">Все още нямате направени поръчки.</p>
                                <a href="/" class="btn btn-danger btn-sm rounded-pill">Започнете пазаруването</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>