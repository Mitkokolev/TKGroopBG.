@model IEnumerable<TKGroopBG.Models.Order>

@{
    ViewData["Title"] = "Управление на поръчки";
}

<div class="container mt-5 fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="logo-text" style="margin:0;">Поръчки</h2>
        <span class="badge bg-dark">Общо: @Model.Count()</span>
    </div>

    <div class="cart-table shadow-sm" style="background: white; border-radius: 15px; overflow: hidden;">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Клиент</th>
                    <th>Дата</th>
                    <th>Сума</th>
                    <th>Статус</th>
                    <th class="text-center">Действие</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    string statusClass = order.Status switch
                    {
                        "Нова" => "border-danger text-danger",
                        "Обработва се" => "border-warning text-warning",
                        "Изпратена" => "border-primary text-primary",
                        "Завършена" => "border-success text-success",
                        _ => "border-secondary text-secondary"
                    };

                    <tr class="align-middle">
                        <td class="ps-4">
                            <div class="fw-bold">@order.CustomerName</div>
                            <small class="text-muted">@order.Phone</small>
                        </td>
                        <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="fw-bold" style="color: var(--tk-red);">@order.TotalPrice.ToString("F2") лв.</td>
                        <td>
                            <span class="badge border @statusClass" style="border-radius: 10px; padding: 5px 10px;">
                                @order.Status
                            </span>
                        </td>
                        <td class="text-center pe-4">
                            <form asp-action="UpdateStatus" method="post" class="d-inline-flex gap-2">
                                <input type="hidden" name="id" value="@order.Id" />
                                <select name="newStatus" class="form-select form-select-sm" onchange="this.form.submit()" style="width: auto; border-radius: 8px;">
                                    <option value="Нова" selected="@(order.Status == "Нова")">Нова</option>
                                    <option value="Обработва се" selected="@(order.Status == "Обработва се")">Обработва се</option>
                                    <option value="Изпратена" selected="@(order.Status == "Изпратена")">Изпратена</option>
                                    <option value="Завършена" selected="@(order.Status == "Завършена")">Завършена</option>
                                </select>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>