@model IEnumerable<TKGroopBG.Models.Gallery>

@{
    ViewData["Title"] = "Нашите Проекти";
}

<style>
    .projects-header {
        text-align: center;
        margin-bottom: 50px;
        margin-top: 30px;
    }

        .projects-header h1 {
            color: #A31E23;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 30px;
        padding-bottom: 50px;
    }

    .project-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        text-decoration: none !important;
        color: inherit;
        display: flex;
        flex-direction: column;
        border: 1px solid #eee;
    }

        .project-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(163, 30, 35, 0.2);
        }

    .project-image-wrapper {
        height: 250px;
        overflow: hidden;
        position: relative;
    }

        .project-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .project-card:hover .project-image-wrapper img {
        transform: scale(1.1);
    }

    .project-content {
        padding: 20px;
        flex-grow: 1;
    }

        .project-content h3 {
            color: #333;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .project-content p {
            color: #666;
            font-size: 0.9rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

    .admin-actions {
        padding: 15px;
        background: #f8f9fa;
        border-top: 1px solid #eee;
        display: flex;
        gap: 10px;
    }
</style>

<div class="container">
    <div class="projects-header">
        <h1>Нашите Реализирани Проекти</h1>
        <p class="text-muted">Разгледайте качеството на нашата работа чрез нашите завършени обекти</p>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-danger rounded-pill px-4 mt-3">
                <i class="fas fa-plus me-2"></i> Добави нов проект
            </a>
        }
    </div>

    <div class="project-grid">
        @foreach (var item in Model)
        {
            <div class="project-card-wrapper">
                <a asp-action="Details" asp-route-id="@item.Id" class="project-card">
                    <div class="project-image-wrapper">
                        @if (!string.IsNullOrEmpty(item.ImageFileName))
                        {
                            <img src="/gallery-images/@item.ImageFileName" alt="@item.Title">
                        }
                        else
                        {
                            <img src="/images/no-image.jpg" alt="No Image">
                        }
                    </div>
                    <div class="project-content">
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>
                    </div>
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <div class="admin-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark flex-grow-1">Редактирай</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger flex-grow-1">Изтрий</a>
                    </div>
                }
            </div>
        }
    </div>
</div>