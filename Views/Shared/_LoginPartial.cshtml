@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item d-flex align-items-center gap-3">
            <div class="user-greeting d-none d-md-block">
                <span class="text-muted">Здравей,</span>
                <strong class="text-dark">@User.Identity?.Name?.Split('@')[0]</strong>
            </div>

            <button class="btn-account-circle" onclick="toggleUserSidebar()">
                <i class="fas fa-user-circle"></i>
            </button>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Вход</a>
        </li>
    }
</ul>