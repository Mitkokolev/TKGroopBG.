@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    var title = ViewData["Title"] ?? "TKGroopBG";
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - TKGroopBG</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <a asp-controller="Home" asp-action="Index" class="home-btn" title="Начало">
        <i class="fas fa-home" aria-hidden="true"></i>
    </a>

    <button type="button" class="back-btn" title="Назад" onclick="history.back()">
        <i class="fas fa-arrow-left" aria-hidden="true"></i>
    </button>

    <a asp-controller="Cart" asp-action="Index" class="cart-btn" title="Количка">
        <i class="fas fa-shopping-cart"></i>
        <span id="cart-count" class="cart-count-badge">0</span>
    </a>

    <div class="auth-bar">
        @if (SignInManager.IsSignedIn(User))
        {
            <div class="auth-user d-flex align-items-center gap-2">
                <span class="auth-hello d-none d-md-inline">Здравей, @User.Identity?.Name?.Split('@')[0]</span>
                <button type="button" class="btn-account-circle" onclick="toggleUserSidebar()">
                    <i class="fas fa-user-circle"></i>
                </button>
            </div>
        }
        else
        {
            <a class="btn-auth" asp-area="Identity" asp-page="/Account/Login">Вход</a>
            <a class="btn-auth btn-auth-danger" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
        }
    </div>

    @if (SignInManager.IsSignedIn(User))
    {
        <div id="userSidebar" class="user-sidebar">
            <div class="text-end mb-4">
                <button type="button" class="btn-close" onclick="toggleUserSidebar()"></button>
            </div>

            <div class="text-center mb-4">
                <i class="fas fa-user-circle fa-4x text-danger mb-2"></i>
                <h6 class="text-muted mb-1">Влязохте като:</h6>
                <strong class="d-block mb-3">@User.Identity?.Name</strong>
                <hr />
            </div>

            <div class="list-group list-group-flush">
                <a asp-controller="Orders" asp-action="MyOrders" class="list-group-item list-group-item-action border-0 py-3">
                    <i class="fas fa-box-open me-2 text-danger"></i> Моите поръчки
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="list-group-item list-group-item-action border-0 py-3">
                    <i class="fas fa-user-cog me-2 text-danger"></i> Настройки на профила
                </a>

                <div class="mt-4 px-3">
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="~/" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 py-2 shadow-sm">
                            <i class="fas fa-sign-out-alt me-2"></i> Изход
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleUserSidebar()"></div>
    }

    <main class="tk-main">
        @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
        {
            <partial name="_AdminBar" />
        }

        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-section">
                <strong>TKGroopBG</strong><br />
                Офис: Изгрев бл. 5
            </div>

            <div class="footer-section">
                <span>Email:</span>
                <a href="mailto:TKGroopBG@abv.bg">TKGroopBG@abv.bg</a><br />
                <span>Телефон:</span>
                <a href="tel:+35987723967">087723967</a>
            </div>

            <div class="footer-section footer-social">
                <a href="https://facebook.com" target="_blank" rel="noopener noreferrer">
                    <i class="fab fa-facebook"></i>
                </a>
            </div>
        </div>
        <p class="footer-copy">© @DateTime.Now.Year TKGroopBG — Всички права запазени</p>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Функция за отваряне/затваряне на панела
        function toggleUserSidebar() {
            const sidebar = document.getElementById('userSidebar');
            const overlay = document.getElementById('sidebarOverlay');
            if(sidebar) {
                sidebar.classList.toggle('active');
                overlay.classList.toggle('active');
            }
        }

        // Количка функционалност
        function updateCartCount() {
            let count = 0;
            try {
                const raw = localStorage.getItem("tk_cart");
                if (raw) {
                    const arr = JSON.parse(raw);
                    if (Array.isArray(arr)) count = arr.length;
                }
            } catch (e) { count = 0; }

            const badge = document.getElementById("cart-count");
            if (badge) {
                badge.textContent = count;
                badge.style.display = count > 0 ? "flex" : "none";
            }
        }

        document.addEventListener("DOMContentLoaded", updateCartCount);
        window.addEventListener("storage", function (e) {
            if (e.key === "tk_cart") updateCartCount();
        });
    </script>
</body>
</html>