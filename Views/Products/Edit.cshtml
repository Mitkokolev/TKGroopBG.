@model TKGroopBG.Models.Products

@{
    ViewData["Title"] = "Редактиране на продукт";
}

<div class="container mt-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Category" asp-route-id="@Model.Category" class="btn btn-outline-secondary rounded-circle me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 class="text-danger fw-bold m-0">Редактиране на продукт: @Model.Name</h2>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageFileName" />
        <input type="hidden" name="variantsJson" id="variantsJson" />
        <input type="hidden" name="colorsJson" id="colorsJson" />

        <div class="row">
            @* --- ЛЯВА КОЛОНА: ИНФОРМАЦИЯ --- *@
            <div class="col-md-7">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Основна информация</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="fw-bold mb-1">Име на продукта</label>
                            <input asp-for="Name" class="form-control form-control-lg" />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold mb-1">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label class="fw-bold mb-1">Базова цена (€)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light">€</span>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold mb-1">Категория</label>
                                <select asp-for="Category" class="form-select" asp-items="@(new SelectList(ViewBag.Categories))"></select>
                            </div>
                        </div>
                    </div>
                </div>

                @* СЕКЦИЯ ВАРИАНТИ *@
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                        <h5 class="mb-0"><i class="fas fa-layer-group me-2"></i>Варианти (Стъклопакети)</h5>
                        <button type="button" class="btn btn-sm btn-light fw-bold" onclick="addVariant()">
                            <i class="fas fa-plus me-1"></i> Добави
                        </button>
                    </div>
                    <div class="card-body p-4">
                        <div id="variantsContainer">
                            @if (Model.Variants != null)
                            {
                                foreach (var v in Model.Variants)
                                {
                                    <div class="input-group mb-2 variant-row shadow-sm">
                                        <input type="text" class="form-control v-name" value="@v.Name" placeholder="Име на вариант">
                                        <span class="input-group-text">+ €</span>
                                        <input type="number" step="0.01" class="form-control v-price" value="@v.AdditionalPrice.ToString("0.00").Replace(',','.')" placeholder="Цена">
                                        <button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* --- ДЯСНА КОЛОНА: СНИМКИ И ЦВЕТОВЕ --- *@
            <div class="col-md-5">
                <div class="card shadow-sm border-0 mb-4 text-center p-3">
                    <label class="fw-bold mb-2 d-block">Текуща основна снимка</label>
                    <div class="position-relative mb-3">
                        <img src="/product-images/@Model.ImageFileName" class="img-thumbnail" style="max-height: 180px; width: 100%; object-fit: contain;" />
                    </div>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    <small class="text-muted">Избери нов файл само ако искаш да смениш основната снимка</small>
                </div>

                @* СЕКЦИЯ ЦВЕТОВЕ И СНИМКИ ЗА ТЯХ *@
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
                        <h5 class="mb-0"><i class="fas fa-palette me-2"></i>Цветове и специфични снимки</h5>
                        <button type="button" class="btn btn-sm btn-light fw-bold" onclick="addColor()">
                            <i class="fas fa-plus me-1"></i> Добави
                        </button>
                    </div>
                    <div class="card-body p-3">
                        <div id="colorsContainer">
                            @if (Model.Colors != null)
                            {
                                foreach (var c in Model.Colors)
                                {
                                    var colorImg = Model.Images?.FirstOrDefault(i => i.ColorHex == c.ColorHex)?.ImagePath;
                                    <div class="border p-3 mb-2 rounded color-row bg-light shadow-sm">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <input type="text" class="form-control c-name" value="@c.ColorName" placeholder="Име">
                                            <input type="color" class="form-control form-control-color c-hex" value="@c.ColorHex" style="width: 50px;">
                                            <button type="button" class="btn btn-sm btn-outline-danger ms-auto" onclick="this.closest('.color-row').remove()">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="flex-grow-1">
                                                <input type="file" name="colorFiles" class="form-control form-control-sm c-file" accept="image/*" onchange="previewColorFile(this)">
                                            </div>
                                            @if (!string.IsNullOrEmpty(colorImg))
                                            {
                                                <img src="/product-images/@colorImg" class="rounded border c-preview" style="width: 38px; height: 38px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="rounded border bg-white c-preview" style="width: 38px; height: 38px; display:flex; align-items:center; justify-content:center;">
                                                    <i class="fas fa-image text-muted" style="font-size: 12px;"></i>
                                                </div>
                                            }
                                        </div>
                                        <small class="text-muted" style="font-size: 10px;">Качи снимка само ако искаш да я смениш</small>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                @* ДЕЙСТВИЯ *@
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <button type="submit" onclick="prepareJson()" class="btn btn-danger btn-lg w-100 fw-bold py-3 shadow">
                            <i class="fas fa-save me-2"></i> ЗАПАЗИ ПРОМЕНИТЕ
                        </button>
                        <a asp-action="Category" asp-route-id="@Model.Category" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Отказ</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function addVariant() {
            const html = `
            <div class="input-group mb-2 variant-row shadow-sm">
                <input type="text" class="form-control v-name" placeholder="Име на вариант">
                <span class="input-group-text">+ €</span>
                <input type="number" step="0.01" class="form-control v-price" placeholder="Цена">
                <button type="button" class="btn btn-danger" onclick="this.parentElement.remove()">
                    <i class="fas fa-trash"></i>
                </button>
            </div>`;
            document.getElementById('variantsContainer').insertAdjacentHTML('beforeend', html);
        }

        function addColor() {
            const html = `
            <div class="border p-3 mb-2 rounded color-row bg-light shadow-sm">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <input type="text" class="form-control c-name" placeholder="Име">
                    <input type="color" class="form-control form-control-color c-hex" value="#ffffff" style="width: 50px;">
                    <button type="button" class="btn btn-sm btn-outline-danger ms-auto" onclick="this.closest('.color-row').remove()">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <div class="flex-grow-1">
                        <input type="file" name="colorFiles" class="form-control form-control-sm c-file" accept="image/*" onchange="previewColorFile(this)">
                    </div>
                    <div class="rounded border bg-white c-preview" style="width: 38px; height: 38px; display:flex; align-items:center; justify-content:center;">
                         <i class="fas fa-image text-muted" style="font-size: 12px;"></i>
                    </div>
                </div>
            </div>`;
            document.getElementById('colorsContainer').insertAdjacentHTML('beforeend', html);
        }

        function previewColorFile(input) {
            const preview = input.closest('.color-row').querySelector('.c-preview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    if(preview.tagName === 'IMG') {
                        preview.src = e.target.result;
                    } else {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = "rounded border c-preview";
                        img.style = "width: 38px; height: 38px; object-fit: cover;";
                        preview.replaceWith(img);
                    }
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function prepareJson() {
            const variants = [];
            document.querySelectorAll('.variant-row').forEach(row => {
                variants.push({
                    Name: row.querySelector('.v-name').value,
                    AdditionalPrice: parseFloat(row.querySelector('.v-price').value) || 0
                });
            });

            const colors = [];
            document.querySelectorAll('.color-row').forEach((row, index) => {
                const fileInput = row.querySelector('.c-file');
                colors.push({
                    ColorName: row.querySelector('.c-name').value,
                    ColorHex: row.querySelector('.c-hex').value,
                    FileIndex: fileInput.files.length > 0 ? index : -1
                });
            });

            document.getElementById('variantsJson').value = JSON.stringify(variants);
            document.getElementById('colorsJson').value = JSON.stringify(colors);
        }
    </script>
}