@model TKGroopBG.Models.Products
@using System.Text.Json

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var fallback = Url.Content("~/images/default.jpg");
    var mainImagePath = string.IsNullOrEmpty(Model.ImageFileName)
        ? fallback
        : Url.Content("~/product-images/" + Model.ImageFileName);

    var productJson = JsonSerializer.Serialize(new
    {
        id = Model.Id,
        name = Model.Name,
        basePrice = Model.Price,
        category = Model.Category
    });
}

<div class="container mt-5 product-details-page">
    <div class="row gx-4">

        <div class="col-lg-7">
            <div class="product-main-image-box shadow-sm mb-3 position-relative">
                <img id="mainProductImage" src="@mainImagePath" alt="@Model.Name" class="img-fluid rounded border" />
            </div>

            <div class="d-flex gap-2 overflow-auto py-2">
                @foreach (var img in Model.Images.Where(i => string.IsNullOrEmpty(i.ColorHex)))
                {
                    <img src="~/product-images/@img.ImagePath" class="img-thumbnail" style="width: 80px; cursor:pointer;" onclick="document.getElementById('mainProductImage').src = this.src" />
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="p-4 border rounded bg-white shadow-sm">
                <h2 class="text-danger fw-bold mb-2">@Model.Name</h2>
                <p class="text-secondary small">@Model.Description</p>
                <hr />

                <div class="mb-4">
                    <label class="form-label small fw-bold d-block mb-2">Цвят на профила:</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var color in Model.Colors)
                        {
                            var colorImg = Model.Images.FirstOrDefault(i => i.ColorHex == color.ColorHex)?.ImagePath;
                            var finalImgPath = colorImg != null ? Url.Content("~/product-images/" + colorImg) : mainImagePath;

                            <div class="color-item text-center">
                                <button type="button"
                                        class="color-circle shadow-sm"
                                        style="background-color: @color.ColorHex; width: 40px; height: 40px; border-radius: 50%; border: 3px solid #fff; outline: 1px solid #ddd;"
                                        data-image="@finalImgPath"
                                        data-name="@color.ColorName"
                                        onclick="updateProductColor(this)">
                                </button>
                            </div>
                        }
                    </div>
                    <small id="selectedColorLabel" class="d-block mt-2 text-muted" style="font-size: 11px;">Изберете цвят на профила</small>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <label class="form-label small fw-bold">Височина (мм)</label>
                        <input id="heightMm" type="number" class="form-control form-control-lg" placeholder="1200" oninput="calculateTotal()" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-bold">Ширина (мм)</label>
                        <input id="widthMm" type="number" class="form-control form-control-lg" placeholder="800" oninput="calculateTotal()" />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold d-block mb-3">Опции за стъклопакет:</label>
                    @foreach (var variant in Model.Variants)
                    {
                        <div class="variant-option border rounded p-3 mb-2 d-flex justify-content-between align-items-center" style="cursor: pointer;" onclick="selectVariant(this, @variant.AdditionalPrice, '@variant.Name')">
                            <div>
                                <input type="radio" name="productVariant" class="form-check-input me-2" />
                                <span>@variant.Name</span>
                            </div>
                            <span class="text-danger fw-bold">+@variant.AdditionalPrice лв.</span>
                        </div>
                    }
                </div>

                <div class="price-box bg-light p-3 rounded mb-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Обща сума:</span>
                        <h3 id="displayPrice" class="fw-bold text-danger mb-0">-- лв.</h3>
                    </div>
                </div>

                <button id="addToCartBtn" class="btn btn-danger btn-lg w-100 py-3 fw-bold shadow">
                    ДОБАВИ В КОЛИЧКАТА
                </button>
            </div>
        </div>

    </div>
</div>

<style>
    .color-circle.active {
        outline: 2px solid #dc3545 !important;
        transform: scale(1.1);
    }

    .variant-option.active {
        border-color: #dc3545 !important;
        background-color: #fff5f5;
    }

    .variant-option:hover {
        background-color: #f8f9fa;
    }
</style>

@section Scripts {
    <script>
        const product = @Html.Raw(productJson);
        let selectedVariantPrice = 0;
        let selectedVariantName = "";
        let selectedColorName = "";

        function updateProductColor(btn) {
            // Махаме активния клас от всички кръгчета
            document.querySelectorAll('.color-circle').forEach(c => c.classList.remove('active'));
            // Слагаме го на избраното
            btn.classList.add('active');

            // Сменяме главната снимка
            const newImg = btn.getAttribute('data-image');
            document.getElementById('mainProductImage').src = newImg;

            // Обновяваме етикета с името на цвета
            const colorName = btn.getAttribute('data-name');
            document.getElementById('selectedColorLabel').innerText = "Избран цвят: " + colorName;
            selectedColorName = colorName;
        }

        function selectVariant(element, price, name) {
            document.querySelectorAll('.variant-option').forEach(v => v.classList.remove('active'));
            element.classList.add('active');
            element.querySelector('input').checked = true;

            selectedVariantPrice = price;
            selectedVariantName = name;
            calculateTotal();
        }

        function calculateTotal() {
            const h = parseFloat(document.getElementById('heightMm').value);
            const w = parseFloat(document.getElementById('widthMm').value);
            const priceLabel = document.getElementById('displayPrice');

            if (h > 0 && w > 0) {
                const areaM2 = (h / 1000) * (w / 1000);
                const total = (areaM2 * product.basePrice) + selectedVariantPrice;
                priceLabel.innerText = total.toFixed(2) + " лв.";
            } else {
                priceLabel.innerText = "-- лв.";
            }
        }

        document.getElementById('addToCartBtn').addEventListener('click', function() {
            const h = document.getElementById('heightMm').value;
            const w = document.getElementById('widthMm').value;

            if (!h || !w || !selectedVariantName) {
                alert("Моля, въведете размери и изберете опция!");
                return;
            }

            alert("Продуктът е добавен в количката!");
        });
    </script>
}