@model TKGroopBG.Models.Products
@using System.Text.Json

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var fallback = Url.Content("~/images/default.jpg");
    var mainImagePath = string.IsNullOrEmpty(Model.ImageFileName)
        ? fallback
        : Url.Content("~/product-images/" + Model.ImageFileName);

    var productJson = JsonSerializer.Serialize(new
    {
        id = Model.Id,
        name = Model.Name,
        basePrice = Model.Price,
        category = Model.Category,
        isCustomSize = Model.IsCustomSize
    });
}

@* ДОБАВЕНИ СТИЛОВЕ ЗА ЦВЕТОВЕТЕ *@
<style>
    .color-circle {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        border: 2px solid #eee;
        display: inline-block;
        padding: 0;
        transition: all 0.2s ease;
        position: relative;
    }

        .color-circle:hover {
            transform: scale(1.1);
            border-color: #dc3545;
        }

        .color-circle.active {
            border-color: #333;
            box-shadow: 0 0 0 2px #fff, 0 0 0 4px #dc3545 !important;
        }

    .variant-option.active {
        border-color: #dc3545 !important;
        background-color: #fff5f5 !important;
    }

    .product-main-image-box img {
        width: 100%;
        height: 500px;
        object-fit: contain;
    }
</style>

@Html.AntiForgeryToken()

<div class="container mt-5 product-details-page">
    <div class="row gx-4">
        @* Лява част: Снимки *@
        <div class="col-lg-7">
            <div class="product-main-image-box shadow-sm mb-3 position-relative bg-white rounded p-2">
                <img id="mainProductImage" src="@mainImagePath" alt="@Model.Name" class="img-fluid rounded border" />
            </div>

            <div class="d-flex gap-2 overflow-auto py-2 thumb-gallery">
                @foreach (var img in Model.Images.Where(i => string.IsNullOrEmpty(i.ColorHex)))
                {
                    <img src="~/product-images/@img.ImagePath" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover; cursor:pointer;" onclick="document.getElementById('mainProductImage').src = this.src" />
                }
            </div>
        </div>

        @* Дясна част: Опции и Поръчка *@
        <div class="col-lg-5">
            <div class="p-4 border rounded bg-white shadow-sm">
                <h2 class="text-dark fw-bold mb-2">@Model.Name</h2>
                <p class="text-secondary small">@Model.Description</p>
                <hr />

                @* 1. Избор на цвят *@
                @if (Model.Colors != null && Model.Colors.Any())
                {
                    <div class="mb-4">
                        <label class="form-label small fw-bold d-block mb-2 text-uppercase text-muted">Цвят на профила:</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var color in Model.Colors)
                            {
                                var colorImg = Model.Images.FirstOrDefault(i => i.ColorHex == color.ColorHex)?.ImagePath;
                                var finalImgPath = colorImg != null ? Url.Content("~/product-images/" + colorImg) : mainImagePath;

                                <div class="color-item" title="@color.ColorName">
                                    <button type="button"
                                            class="color-circle shadow-sm"
                                            style="background-color: @color.ColorHex;"
                                            data-image="@finalImgPath"
                                            data-name="@color.ColorName"
                                            onclick="updateProductColor(this)">
                                    </button>
                                </div>
                            }
                        </div>
                        <small id="selectedColorLabel" class="d-block mt-2 text-danger fw-bold" style="font-size: 13px;">Цвят: Стандартен</small>
                    </div>
                }

                @* 2. Калкулатор за размери *@
                @if (Model.IsCustomSize)
                {
                    <div class="row g-3 mb-4 bg-light p-3 rounded border">
                        <div class="col-12 mb-1"><span class="badge bg-danger">Продукт по Ваши размери</span></div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Височина (мм)</label>
                            <input id="heightMm" type="number" class="form-control form-control-lg border-danger" placeholder="напр. 1200" oninput="calculateTotal()" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Ширина (мм)</label>
                            <input id="widthMm" type="number" class="form-control form-control-lg border-danger" placeholder="напр. 800" oninput="calculateTotal()" />
                        </div>
                    </div>
                }

                @* 3. Варианти *@
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    <div class="mb-4">
                        <label class="form-label small fw-bold d-block mb-2 text-uppercase text-muted">Опции:</label>
                        @foreach (var variant in Model.Variants)
                        {
                            <div class="variant-option border rounded p-3 mb-2 d-flex justify-content-between align-items-center bg-white shadow-sm" style="cursor: pointer;" onclick="selectVariant(this, @variant.AdditionalPrice, '@variant.Name')">
                                <div class="d-flex align-items-center">
                                    <input type="radio" name="productVariant" class="form-check-input me-3" style="cursor: pointer;" />
                                    <span class="small fw-bold">@variant.Name</span>
                                </div>
                                <span class="text-danger fw-bold">+@variant.AdditionalPrice.ToString("0.00") €</span>
                            </div>
                        }
                    </div>
                }

                @* 4. Количество и Цена *@
                <div class="price-box bg-dark text-white p-3 rounded mb-4 d-flex justify-content-between align-items-center shadow">
                    <div>
                        <span class="small opacity-75 d-block">Обща сума:</span>
                        <h3 id="displayPrice" class="fw-bold mb-0">@Model.Price.ToString("0.00") €</h3>
                    </div>

                    <div class="quantity-control d-flex align-items-center bg-white rounded-pill p-1">
                        <button class="btn btn-sm btn-light rounded-circle" onclick="changeQty(-1)"><i class="fas fa-minus text-dark"></i></button>
                        <input type="number" id="orderQty" class="form-control form-control-sm text-center border-0 fw-bold" value="1" min="1" style="width: 45px; pointer-events: none;">
                        <button class="btn btn-sm btn-light rounded-circle" onclick="changeQty(1)"><i class="fas fa-plus text-dark"></i></button>
                    </div>
                </div>

                <button id="addToCartBtn" class="btn btn-danger btn-lg w-100 py-3 fw-bold shadow rounded-pill">
                    <i class="fas fa-cart-plus me-2"></i> ДОБАВИ В КОЛИЧКАТА
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const product = @Html.Raw(productJson);
        let selectedVariantPrice = 0;
        let selectedVariantName = "";
        let selectedColorName = "Стандартен";

        function changeQty(val) {
            const qtyInput = document.getElementById('orderQty');
            let current = parseInt(qtyInput.value);
            current += val;
            if (current < 1) current = 1;
            qtyInput.value = current;
            calculateTotal();
        }

        function updateProductColor(btn) {
            document.querySelectorAll('.color-circle').forEach(c => c.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('mainProductImage').src = btn.getAttribute('data-image');
            selectedColorName = btn.getAttribute('data-name');
            document.getElementById('selectedColorLabel').innerText = "Цвят: " + selectedColorName;
        }

        function selectVariant(element, price, name) {
            document.querySelectorAll('.variant-option').forEach(v => v.classList.remove('active'));
            element.classList.add('active');
            element.querySelector('input').checked = true;
            selectedVariantPrice = price;
            selectedVariantName = name;
            calculateTotal();
        }

        function calculateTotal() {
            const qty = parseInt(document.getElementById('orderQty').value);
            let finalUnitPrice = product.basePrice;

            if (product.isCustomSize) {
                const h = parseFloat(document.getElementById('heightMm').value) || 0;
                const w = parseFloat(document.getElementById('widthMm').value) || 0;
                if (h > 0 && w > 0) {
                    const areaM2 = (h / 1000) * (w / 1000);
                    finalUnitPrice = (areaM2 * product.basePrice) + selectedVariantPrice;
                } else {
                    document.getElementById('displayPrice').innerText = "-- €";
                    return;
                }
            } else {
                finalUnitPrice = product.basePrice + selectedVariantPrice;
            }

            const totalPrice = finalUnitPrice * qty;
            document.getElementById('displayPrice').innerText = totalPrice.toFixed(2) + " €";
        }

        document.getElementById('addToCartBtn').addEventListener('click', async function() {
            const qty = document.getElementById('orderQty').value;

            if (product.isCustomSize) {
                const h = document.getElementById('heightMm').value;
                const w = document.getElementById('widthMm').value;
                if (!h || !w) { alert("Моля, въведете размери!"); return; }
            }

            const details = `Цвят: ${selectedColorName}${product.isCustomSize ? `, Размер: ${document.getElementById('widthMm').value}x${document.getElementById('heightMm').value}` : ""}${selectedVariantName ? `, Опция: ${selectedVariantName}` : ""}`;

            const formData = new URLSearchParams();
            formData.append('productId', product.id);
            formData.append('quantity', qty);
            formData.append('details', details);

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const response = await fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: formData
                });

                if (response.ok) {
                    alert("Успешно добавено в количката!");
                    window.location.href = '/Cart';
                } else {
                    alert("Моля, влезте в профила си, за да пазарувате.");
                    window.location.href = '/Identity/Account/Login';
                }
            } catch (error) {
                alert("Грешка при връзката със сървъра.");
            }
        });
    </script>
}